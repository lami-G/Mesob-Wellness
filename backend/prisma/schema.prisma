generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String             @id @default(uuid()) @db.Uuid
  email                 String?            @unique
  password              String?
  fullName              String
  role                  UserRole           @default(STAFF)
  userId                String             @unique
  isExternal            Boolean            @default(false)
  canLogin              Boolean            @default(true)
  centerId              String?            @db.Uuid
  dateOfBirth           DateTime?          @db.Date
  gender                Gender?
  phone                 String?
  profilePicture        String?
  emergencyContactName  String?
  emergencyContactPhone String?
  isActive              Boolean            @default(true)
  isVerified            Boolean            @default(false)
  lastLoginAt           DateTime?          @db.Timestamptz(3)
  createdAt             DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime           @updatedAt @db.Timestamptz(3)
  appointments          Appointment[]
  auditLogs             AuditLog[]
  feedback              Feedback[]
  healthProfile         HealthProfile?
  notifications         Notification[]
  approvedConditions    PatientCondition[] @relation("ApprovedBy")
  patientConditions     PatientCondition?
  center                Center?            @relation(fields: [centerId], references: [id])
  recordedVitals        VitalRecord[]      @relation("RecordedBy")
  vitalsRecords         VitalRecord[]
  wellnessPlans         WellnessPlan[]

  @@index([email])
  @@index([role])
  @@index([centerId])
  @@index([createdAt])
  @@index([userId])
  @@index([isExternal])
  @@map("users")
}

model HealthProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  bloodType         String?
  allergies         String?
  chronicConditions String?
  medications       String?
  vitalsHistory     Json?
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("health_profiles")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String
  resource  String?
  details   Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now()) @db.Timestamptz(3)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([timestamp(sort: Desc)])
  @@map("audit_logs")
}

model VitalRecord {
  id               String                 @id @default(uuid()) @db.Uuid
  userId           String                 @db.Uuid
  recordedBy       String                 @db.Uuid
  weightKg         Float?
  heightCm         Float?
  bmi              Float?
  bmiCategory      BmiCategory?
  systolic         Int?
  diastolic        Int?
  bpCategory       BloodPressureCategory?
  heartRate        Int?
  temperature      Float?
  oxygenSaturation Int?
  glucose          Int?
  glucoseType      String?
  notes            String?
  recordedAt       DateTime               @default(now()) @db.Timestamptz(3)
  recorder         User                   @relation("RecordedBy", fields: [recordedBy], references: [id])
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recordedBy])
  @@index([recordedAt(sort: Desc)])
  @@index([userId, recordedAt(sort: Desc)])
  @@map("vital_records")
}

model Appointment {
  id                 String            @id @default(uuid()) @db.Uuid
  userId             String            @db.Uuid
  scheduledAt        DateTime          @db.Timestamptz(3)
  reason             String
  status             AppointmentStatus @default(WAITING)
  notes              String?
  diagnosis          String?
  prescription       String?
  confirmedAt        DateTime?         @db.Timestamptz(3)
  startedAt          DateTime?         @db.Timestamptz(3)
  completedAt        DateTime?         @db.Timestamptz(3)
  cancelledAt        DateTime?         @db.Timestamptz(3)
  cancellationReason String?
  reminderSentAt     DateTime?         @db.Timestamptz(3)
  reminderCount      Int               @default(0)
  lastReminderBy     String?           @db.Uuid
  createdAt          DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime          @updatedAt @db.Timestamptz(3)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@index([userId, status])
  @@index([scheduledAt, status])
  @@map("appointments")
}

model WellnessPlan {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  planText   String
  goals      String?
  duration   Int?
  conditions Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([userId, isActive])
  @@map("wellness_plans")
}

model Feedback {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  npsScore       Int?
  serviceQuality Int?
  staffBehavior  Int?
  cleanliness    Int?
  waitTime       Int?
  rating         Int?
  comments       String?
  feedbackType   String?  @default("SERVICE")
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([npsScore])
  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("feedback")
}

model Center {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  code      String       @unique
  region    String
  city      String
  address   String
  phone     String?
  email     String?
  status    CenterStatus @default(ACTIVE)
  capacity  Int?
  createdAt DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt DateTime     @updatedAt @db.Timestamptz(3)
  staff     User[]

  @@index([region])
  @@index([status])
  @@index([code])
  @@index([region, status])
  @@map("centers")
}

model Notification {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String               @db.Uuid
  type      NotificationType
  severity  NotificationSeverity @default(MEDIUM)
  title     String
  message   String
  isRead    Boolean              @default(false)
  relatedId String?
  createdAt DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt DateTime             @updatedAt @db.Timestamptz(3)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([severity])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([key])
  @@map("settings")
}

model PatientCondition {
  id              String    @id @default(uuid()) @db.Uuid
  patientId       String    @unique @db.Uuid
  conditions      Json
  calculatedAt    DateTime  @default(now()) @db.Timestamptz(3)
  isNurseApproved Boolean   @default(false)
  approvedAt      DateTime? @db.Timestamptz(3)
  approvedBy      String?   @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(3)
  approver        User?     @relation("ApprovedBy", fields: [approvedBy], references: [id])
  patient         User      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([isNurseApproved])
  @@index([approvedAt])
  @@map("patient_conditions")
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  SYSTEM_ALERT
  WELLNESS_TIP
  FEEDBACK_REQUEST
  USER_REGISTRATION
  DATA_ISSUE
}

enum NotificationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserRole {
  EXTERNAL_PATIENT
  STAFF
  NURSE_OFFICER
  MANAGER
  REGIONAL_OFFICE
  FEDERAL_OFFICE
  SYSTEM_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BmiCategory {
  UNDERWEIGHT
  NORMAL
  OVERWEIGHT
  OBESITY
}

enum BloodPressureCategory {
  NORMAL
  ELEVATED
  HYPERTENSION_STAGE_1
  HYPERTENSION_STAGE_2
  HYPERTENSIVE_CRISIS
}

enum AppointmentStatus {
  WAITING
  IN_PROGRESS
  IN_SERVICE
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING
  CONFIRMED
}

enum CenterStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}
