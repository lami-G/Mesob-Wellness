NODE_ENV=development
PORT=5000

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_postgres_password
DB_NAME=mesob_wellness

# PostgreSQL Connection String (used by Prisma CLI: migrate, generate)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# USER, HOST, PORT, and DATABASE must match DB_USER, DB_HOST, DB_PORT, DB_NAME above.
# The PASSWORD segment (after URL decoding) must match DB_PASS exactly, or the API pool will fail with P1010.
# If they drift apart, the API can fail at runtime with P1010 "denied access on the database".
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/mesob_wellness?schema=public

# JWT Configuration
JWT_SECRET=mesob_jwt_local_2026_strong_key
JWT_EXPIRES_IN=1h

# Optional: Connection Pool Settings
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# DATABASE_POOL_TIMEOUT=30000
