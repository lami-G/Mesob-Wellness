# Set to production when deploying
NODE_ENV=development
PORT=5000

# PostgreSQL Configuration
# Use the same DATABASE_URL value in development and production.
# For Neon, paste the full connection string here.
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/mesob_wellness?schema=public

# Optional overrides if you want explicit DB_* values in local development.
# If omitted, the app derives them from DATABASE_URL.
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASS=your_postgres_password
# DB_NAME=mesob_wellness

# JWT Configuration
JWT_SECRET=mesob_jwt_local_2026_strong_key
JWT_EXPIRES_IN=1h

# Optional: Connection Pool Settings
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# DATABASE_POOL_TIMEOUT=30000
