{
  "name": "mesob-wellness-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json && npm run copy:prisma",
    "postinstall": "prisma generate",
    "copy:prisma": "node -e \"require('fs').cpSync('src/generated', 'dist/generated', {recursive: true})\"",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/email.worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\" --names \"API,WORKER\" --prefix-colors \"cyan,magenta\"",
    "start": "concurrently \"node dist/server.js\" \"node dist/workers/email.worker.js\" --names \"API,WORKER\" --prefix-colors \"cyan,magenta\"",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/workers/email.worker.js",
    "start:all": "concurrently \"npm run start:api\" \"npm run start:worker\" --names \"API,WORKER\" --prefix-colors \"cyan,magenta\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.80.2",
    "concurrently": "^10.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.6.0",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.17.6",
    "@vercel/node": "^5.8.22",
    "nodemon": "^3.0.2",
    "prisma": "^7.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@types/node": "^25.6.0",
    "@types/express": "^5.0.6"
  }
}
